{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code History Viewer",
  "version": "1.13.1",
  "identifier": "com.claude.history-viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "just vite-dev",
    "beforeBuildCommand": "just frontend-build"
  },
  "app": {
    "windows": [
      {
        "titleBarStyle": "Overlay",
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "focus": true,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; connect-src 'self' https://api.github.com https://github.com https://*.githubusercontent.com https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' data: https://fonts.gstatic.com; frame-ancestors 'none'",
      "capabilities": [
        "default",
        "http-requests"
      ]
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/rxg9527/claude-code-history-viewer/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0M0VFM0ZDOTUwMEJFQUIKUldTcnZnQ1YvT00rTk80eUw1MUY2Y0hmZlErekNRN20waGFyLzJkQjlsSGw4Wm9hdmRmT2dFS1QK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13"
    }
  }
}
